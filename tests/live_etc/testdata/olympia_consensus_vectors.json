  "eip7935_adversarial_equilibrium": {
    "_comment": "Game theory: miner hashrate distribution affects gas limit equilibrium. Simulated over 10,000 blocks.",
    "scenarios": [
      {
        "name": "normal_100pct_honest",
        "honest_target": 60000000,
        "honest_pct": 100,
        "adversary_target": null,
        "expected_equilibrium_min_pct": 99,
        "expected_equilibrium_max_pct": 100
      },
      {
        "name": "70_30_split",
        "honest_target": 60000000,
        "honest_pct": 70,
        "adversary_target": 30000000,
        "expected_equilibrium_min_pct": 95,
        "expected_equilibrium_max_pct": 105,
        "_comment": "With 70% honest, equilibrium stays near 60M"
      },
      {
        "name": "50_50_split",
        "honest_target": 60000000,
        "honest_pct": 50,
        "adversary_target": 30000000,
        "expected_equilibrium_range": "below 60M, near or above 30M",
        "_comment": "50/50 favors lower target — equilibrium drifts down"
      },
      {
        "name": "40_60_adversary_majority",
        "honest_target": 60000000,
        "honest_pct": 40,
        "adversary_target": 52000000,
        "expected_equilibrium_range": "near 52M",
        "_comment": ">50% hashrate controls the equilibrium"
      }
    ]
  },

